{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stl-music",
  "main": "src/worker.js",
  "compatibility_date": "2026-06-13",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "MUSIC_KV",
      "id": "029e3ba66a3743bbaf4a2fef5992aae9"
    }
  ],
  "triggers": {
    "crons": ["0 11 * * 2"]
  }
}
